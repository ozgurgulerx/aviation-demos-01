# Local-only predictive migration/mirroring DB settings.
# DO NOT point this file to cloud/runtime databases.

PGHOST=localhost
PGPORT=5432
PGDATABASE=aviationrag_dev
PGUSER=your_local_db_user
# Optional, only if your local Postgres requires password
PGPASSWORD=

# Keep this false unless you intentionally target a cloud/non-local DB.
ALLOW_CLOUD_PREDICTIVE_DB_WRITE=false
